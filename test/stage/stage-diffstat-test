#!/bin/sh
#
# Test staging whole files and whole directories from the diffstat of the stage view.

. libtest.sh
. libgit.sh

export TEST_TIME_NOW=1401046937
export LINES=24

tigrc <<TIGRC
set diff-stat-group = yes
set vertical-split = no
TIGRC

steps '
	:enter
	:view-diff
	:save-display stage-diffstat.screen

	# "u" on a single stat entry stages just that file (search from the top so
	# the cursor lands on the stat line, not a diff header lower down).
	:0
	:/Button
	:status-update
	:save-display stage-after-file.screen

	# "u" on a directory row stages every file below it, nested ones included.
	:0
	:/store/
	:status-update
	:save-display stage-after-group.screen
'

git_init "$work_dir"

test_setup_work_dir()
{
	for path in \
		src/components/Button.tsx \
		src/components/Modal.tsx \
		src/store/actions.ts \
		src/store/reducers.ts \
		README.md
	do
		mkdir -p -- "$(dirname -- "$path")"
		printf 'a\nb\nc\n' > "$path"
		git add -- "$path"
	done
	git_commit --author="$IDENT_A" --message="Initial"
	for path in \
		src/components/Button.tsx \
		src/components/Modal.tsx \
		src/store/actions.ts \
		src/store/reducers.ts \
		README.md
	do
		printf 'a\nCHANGED\nc\n' > "$path"
	done
}

test_tig

