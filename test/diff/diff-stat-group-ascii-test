#!/bin/sh

. libtest.sh
. libgit.sh

export COLUMNS=50

tigrc <<EOF
set diff-stat-group = yes
set line-graphics = ascii
EOF

steps '
	:save-display diff-stat-group-ascii.screen
'

git_init "$work_dir"

test_setup_work_dir()
{
	for path in \
		src/api/client.ts \
		src/api/server.ts \
		src/util.ts
	do
		mkdir -p -- "$(dirname -- "$path")"
		printf 'x\n' > "$path"
		git add -- "$path"
	done
	git_commit -m "Add sources"
}

test_tig show

# "line-graphics = ascii", and anything but "utf-8" on a terminal that is not
# UTF-8, draws the tree with the plain characters instead.
assert_equals 'diff-stat-group-ascii.screen' <<'EOF'
commit edf5a2156f12b4f9dd3c6ac6bededefeca3479af
Refs: [master]
Author:     Committer <c.ommitter@example.net>
AuthorDate: Fri Feb 13 23:31:30 2009 +0000
Commit:     Committer <c.ommitter@example.net>
CommitDate: Fri Feb 13 23:31:30 2009 +0000

    Add sources
---
 src/
 |-- api/
 |   |-- client.ts | 1 +
 |   `-- server.ts | 1 +
 `-- util.ts       | 1 +
 3 files changed, 3 insertions(+)

