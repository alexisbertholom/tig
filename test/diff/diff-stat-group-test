#!/bin/sh

. libtest.sh
. libgit.sh

export COLUMNS=70

tigrc <<EOF
set diff-stat-group = yes
EOF

steps '
	:save-display diff-stat-group.screen
'

git_init "$work_dir"

test_setup_work_dir()
{
	for path in \
		packages/server/source/routes.ts \
		packages/web-application/source/modules/authentication/LoginForm.tsx \
		packages/web-application/source/modules/authentication/LogoutButton.tsx \
		packages/web-application/source/modules/dashboard/Overview.tsx \
		packages/web-application/source/modules/dashboard/widgets/Chart.tsx
	do
		mkdir -p -- "$(dirname -- "$path")"
		printf 'x\n' > "$path"
		git add -- "$path"
	done
	git_commit -m "Add modules"
}

test_tig show

# At 70 columns the paths do not fit, so the shared "packages/" is lifted into a
# single group header and elided from the files below it.
assert_equals 'diff-stat-group.screen' <<EOF
