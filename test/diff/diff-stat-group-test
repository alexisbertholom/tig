#!/bin/sh

. libtest.sh
. libgit.sh

export COLUMNS=50

tigrc <<EOF
set diff-stat-group = yes
set line-graphics = utf-8
EOF

steps '
	:save-display diff-stat-group.screen

	# Move onto a nested stat line (Chart.tsx) and confirm it still resolves
	# to the right file, its path no longer being spelled out in full.
	:15
	:!echo %(file)
	:save-display diff-stat-group-resolve.screen
'

git_init "$work_dir"

test_setup_work_dir()
{
	for path in \
		README.md \
		source/apps/dashboard/components/Overview.tsx \
		source/apps/dashboard/components/widgets/Chart.tsx \
		source/apps/dashboard/store/reducers.ts \
		source/core/api/client.ts \
		zzz-notes.txt
	do
		mkdir -p -- "$(dirname -- "$path")"
		printf 'x\n' > "$path"
		git add -- "$path"
	done
	git_commit -m "Add dashboard"
}

test_tig show

# At 50 columns the dashboard files are laid out as a tree under "source/", each
# directory spelled out once, and a directory holding a single entry folded into
# it ("apps/dashboard/", "store/reducers.ts").  The files git listed at the root
# keep their alphabetical place among the trees (README.md first, zzz last).
assert_equals 'diff-stat-group.screen' <<EOF
commit c192b5e0c414238a0a5f21ba982819b21d69dd39
Refs: [master]
Author:     Committer <c.ommitter@example.net>
AuthorDate: Fri Feb 13 23:31:30 2009 +0000
Commit:     Committer <c.ommitter@example.net>
CommitDate: Fri Feb 13 23:31:30 2009 +0000

    Add dashboard
---
 README.md                     | 1 +
 source/
 ├── apps/dashboard/
 │   ├── components/
 │   │   ├── Overview.tsx      | 1 +
 │   │   └── widgets/Chart.tsx | 1 +
 │   └── store/reducers.ts     | 1 +
 └── core/api/client.ts        | 1 +
 zzz-notes.txt                 | 1 +
 6 files changed, 6 insertions(+)

diff --git a/README.md b/README.md
new file mode 100644
index 0000000..587be6b
--- /dev/null
+++ b/README.md
@@ -0,0 +1 @@
+x
diff --git a/source/apps/dashboard/components/Over
[diff] c192b5e0c414238a0a5f21ba982819b21d69dd3 45%
EOF

assert_equals 'diff-stat-group-resolve.screen' <<EOF
source/apps/dashboard/components/widgets/Chart.tsx



























[pager] echo source/apps/dashboard/components 100%
EOF
