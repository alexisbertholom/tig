#!/bin/sh

. libtest.sh
. libgit.sh

export COLUMNS=50

tigrc <<EOF
set diff-stat-group = yes
EOF

steps '
	:save-display diff-stat-group.screen

	# Move onto a grouped stat line (Overview.tsx) and confirm it still
	# resolves to the right file despite the header and blank-line separators.
	:13
	:!echo %(file)
	:save-display diff-stat-group-resolve.screen
'

git_init "$work_dir"

test_setup_work_dir()
{
	for path in \
		README.md \
		source/apps/dashboard/components/Overview.tsx \
		source/apps/dashboard/components/widgets/Chart.tsx \
		source/apps/dashboard/store/reducers.ts \
		source/core/api/client.ts \
		zzz-notes.txt
	do
		mkdir -p -- "$(dirname -- "$path")"
		printf 'x\n' > "$path"
		git add -- "$path"
	done
	git_commit -m "Add dashboard"
}

test_tig show

# At 50 columns the dashboard files are lifted under a "[source/apps/dashboard/]"
# header followed only by their own files, with blank lines between blocks. The
# unprefixed files keep their alphabetical position (README.md first, zzz last),
# and core/api/client.ts -- which shares only the shallow "source/" -- is left
# ungrouped rather than dragging the group up to it.
assert_equals 'diff-stat-group.screen' <<EOF
commit c192b5e0c414238a0a5f21ba982819b21d69dd39
Refs: [master]
Author:     Committer <c.ommitter@example.net>
AuthorDate: Fri Feb 13 23:31:30 2009 +0000
Commit:     Committer <c.ommitter@example.net>
CommitDate: Fri Feb 13 23:31:30 2009 +0000

    Add dashboard
---
 README.md                    | 1 +

[source/apps/dashboard/]
 components/Overview.tsx      | 1 +
 components/widgets/Chart.tsx | 1 +
 store/reducers.ts            | 1 +

 source/core/api/client.ts    | 1 +
 zzz-notes.txt                | 1 +

 6 files changed, 6 insertions(+)

diff --git a/README.md b/README.md
new file mode 100644
index 0000000..587be6b
--- /dev/null
+++ b/README.md
@@ -0,0 +1 @@
+x
[diff] c192b5e0c414238a0a5f21ba982819b21d69dd3 44%
EOF

assert_equals 'diff-stat-group-resolve.screen' <<EOF
source/apps/dashboard/components/Overview.tsx



























[pager] echo source/apps/dashboard/components 100%
EOF
